NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# 跨域来源，留空表示允许所有来源（开发期）。生产建议填具体域名，如 https://odds.example.com
CORS_ORIGIN=

# Stake 赔率数据 API（只读）。Key 只能放在服务器端，绝不要写入前端代码或构建产物。
# 支持空配置：留空时后端会打印警告，但仍可对接无需鉴权的公开端点，不会让前端白屏。
STAKE_ODDS_API_KEY=
STAKE_ODDS_API_BASE_URL=https://odds-data.stake.com

# Stake 世界杯赛事路径
STAKE_SPORT=soccer
STAKE_CATEGORY=international
STAKE_TOURNAMENT=world-cup
WORLD_CUP_FILTER_TERMS=world cup,fifa world cup,world-cup,世界杯

# SQLite 数据库路径（生产部署指向 /opt/stake-worldcup-odds-monitor/data/odds.sqlite）
DATABASE_URL=./data/stake-odds.sqlite

# 世界杯实时比分源。默认接入开源 worldcup26.ir，只用于比分/结束状态展示。
SCORE_PROVIDER=worldcup26
SCORE_API_BASE_URL=https://worldcup26.ir
SCORE_API_INTERVAL_MS=15000

# 抓取队列
REQUEST_CONCURRENCY=2
DEFAULT_REQUEST_DELAY_MS=450
REQUEST_TIMEOUT_MS=15000
MAX_FIXTURES=64

# 调度节奏（毫秒）
SCHEDULER_TICK_MS=1000
FIXTURE_LIST_INTERVAL_MS=60000
INTERVAL_WATCHED_MS=1500
INTERVAL_LIVE_MS=2000
INTERVAL_STARTING_SOON_MS=8000
INTERVAL_TODAY_MS=45000
INTERVAL_FUTURE_MS=300000
STARTING_SOON_WINDOW_MS=1800000

# 开发测试接口 /api/mock-change（生产默认关闭）
ENABLE_MOCK_API=true

PUBLIC_RATE_LIMIT_MAX=600
PUBLIC_RATE_LIMIT_WINDOW=1 minute
